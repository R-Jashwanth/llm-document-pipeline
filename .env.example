# ==============================================================================
# Autonomous Business Document Agent - Environment Configuration Example
# ==============================================================================
# Copy this file to '.env' and fill in the values before starting the application.
# Do NOT commit the actual '.env' file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# API Configuration
# ------------------------------------------------------------------------------
# Your Google Gemini API Key. Get one from Google AI Studio.
# Required for running the planner, generator, and reflection modules.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use. Options with free-tier quotas:
#   gemini-2.0-flash  → 1,500 req/day (recommended default)
#   gemini-2.5-flash  → 20 req/day (low free quota, use only with paid plan)
#   gemini-1.5-flash  → 1,500 req/day
GEMINI_MODEL=gemini-2.0-flash

# ------------------------------------------------------------------------------
# Server Configuration (Optional)
# ------------------------------------------------------------------------------
# The host and port for the FastAPI uvicorn server.
HOST=127.0.0.1
PORT=8000
ENVIRONMENT=development  # development, staging, production

# ------------------------------------------------------------------------------
# Logging Configuration (Optional)
# ------------------------------------------------------------------------------
# Available levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
